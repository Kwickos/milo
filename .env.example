# ─── Cœur ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Canal : 'loopmessage' (iMessage) ou 'console' (test local — réponses affichées dans les logs)
MILO_CHANNEL=loopmessage

# ─── Anthropic (le cerveau) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
MILO_MODEL=claude-opus-4-8
MILO_MODEL_LIGHT=claude-haiku-4-5
# Optionnel — router via OpenRouter (endpoint NATIF Anthropic : garde tool use + web_search + thinking) :
#   ANTHROPIC_BASE_URL=https://openrouter.ai/api
#   ANTHROPIC_API_KEY=<clé OpenRouter>   et   MILO_MODEL=anthropic/claude-opus-4.8
# Vide = API Anthropic directe (recommandé, fidélité maximale).
ANTHROPIC_BASE_URL=

# ─── LoopMessage (canal iMessage) — dashboard.loopmessage.com ───────────
# Clé d'API "Authorization" (obligatoire pour envoyer)
LOOPMESSAGE_AUTH_KEY=
# Nom d'expéditeur (prod). En sandbox il est IGNORÉ → laisse vide.
LOOPMESSAGE_SENDER_NAME=
# Valeur du header Authorization que TU choisis dans la config webhook du dashboard
# (Milo la vérifie sur chaque webhook entrant). À renseigner dès que tu exposes le webhook.
LOOPMESSAGE_WEBHOOK_SECRET=

# ─── Voyage AI (embeddings mémoire — optionnel) ─────────
# Sans clé : la mémoire marche en recherche plein-texte. Avec clé : recherche sémantique.
# Modèles possibles : voyage-3.5, voyage-4, voyage-4-large (dimension forcée à 1024).
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5

# ─── Recherche web optimisée (optionnel, recommandé) ────
# Exa /answer : ~10-50x moins de tokens que la recherche native. Clé gratuite : dashboard.exa.ai
EXA_API_KEY=
# Repli optionnel : Perplexity Sonar (CB requise)
PPLX_API_KEY=

# ─── Postgres (+ pgvector) ──────────────────────────────
DATABASE_URL=postgres://milo:milo@localhost:5433/milo

# ─── Redis (file de jobs BullMQ) ────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Liste blanche (numéros E.164, séparés par virgule) ─
MILO_ALLOWLIST=+33600000000
